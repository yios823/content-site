---
const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? "Untitled";
const description = frontmatter?.description ?? "";
---
<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <style>
      :root {
        --text: #1a1a1a;
        --muted: #666;
        --link: #0a66c2;
        --bg: #fafafa;
        --max: 720px;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        line-height: 1.6;
        color: var(--text);
        background: var(--bg);
      }
      body { margin: 0; }
      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 2.5rem 1.25rem 6rem;
      }
      h1 { font-size: 2rem; line-height: 1.2; margin: 0 0 0.5rem; }
      h2 { margin-top: 2.5rem; }
      h3 { margin-top: 1.75rem; }
      p { margin: 1rem 0; }
      a { color: var(--link); }
      img { max-width: 100%; height: auto; }
      ul, ol { padding-left: 1.5rem; }
      table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
      th, td { border: 1px solid #ddd; padding: 0.5rem 0.75rem;
               text-align: left; }
      th { background: #f0f0f0; }
      blockquote {
        border-left: 4px solid #ddd;
        padding: 0.25rem 1rem;
        color: var(--muted);
        margin: 1.25rem 0;
        font-style: italic;
      }
      code { background: #f0f0f0; padding: 0.1rem 0.3rem;
             border-radius: 3px; font-size: 0.95em; }
      pre code { display: block; padding: 1rem; overflow-x: auto; }
      .meta { color: var(--muted); font-size: 0.95rem; margin-bottom: 2rem; }
      footer { margin-top: 4rem; font-size: 0.9rem; color: var(--muted); }
    </style>
  </head>
  <body>
    <main>
      <article>
        <h1>{title}</h1>
        {frontmatter?.publishDate && (
          <p class="meta">{frontmatter.publishDate}</p>
        )}
        <slot />
      </article>
      <footer>
        <p>
          Affiliate disclosure: This page contains Amazon India affiliate
          links. We earn a small commission on qualifying purchases at no
          extra cost to you.
        </p>
      </footer>
    </main>
  </body>
</html>
