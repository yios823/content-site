---
const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? "Untitled";
const description = frontmatter?.description ?? "";
const publishDate = frontmatter?.publishDate ?? "";
const pillar = frontmatter?.pillar ?? "";
const base = "/content-site";
---
<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Home Espresso India</title>
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#FFFBF7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#18120D" media="(prefers-color-scheme: dark)" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="Home Espresso India" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Roboto+Serif:wght@400;600;700&family=Roboto+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href={`${base}/styles.css`} />
    <link rel="icon" href={`data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop offset='0' stop-color='%236F4F38'/%3E%3Cstop offset='1' stop-color='%23735946'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='32' height='32' rx='8' fill='url(%23g)'/%3E%3Cpath d='M9 21q-1.2 0-2-.8-.8-.8-.8-2.2v-7q0-1.4.8-2.2.8-.8 2-.8h7v3h-7v7h7v3Zm10 0v-3h3v-7h-3V8h6v13Z' fill='%23fff'/%3E%3C/svg%3E`} />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a class="site-brand" href={`${base}/`}>Home Espresso India</a>
      </nav>
    </header>
    <main>
      <article class="article-page">
        <h1>{title}</h1>
        {publishDate && (
          <p class="meta">{pillar && `Sub-pillar ${pillar} · `}{publishDate}</p>
        )}
        <slot />
        <footer class="affiliate-footer">
          <p>
            Affiliate disclosure: This page contains Amazon India affiliate
            links. We earn a small commission on qualifying purchases at no
            extra cost to you.
          </p>
        </footer>
      </article>
    </main>
  </body>
</html>
