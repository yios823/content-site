---
const base = "/content-site";
const articles = [
  {
    title:
      "Semi-Automatic vs Super-Automatic Espresso Machines: Which Type " +
      "Fits an Indian Kitchen?",
    href: `${base}/semi-automatic-vs-super-automatic-espresso-machine-india/`,
    description:
      "Decision-criteria comparison framed for Indian kitchens, 220V, " +
      "hard water, monsoon humidity, and compact counters.",
    pillar: "1A",
    publishDate: "2026-05-27",
  },
];
---
<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Home Espresso India: Buyer Guides and Reviews</title>
    <meta
      name="description"
      content="Practical, India-focused guides to choosing and using a home espresso machine. 220V, hard water, monsoon humidity, INR pricing."
    />
    <meta name="theme-color" content="#FFFBF7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#18120D" media="(prefers-color-scheme: dark)" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Home Espresso India: Buyer Guides and Reviews" />
    <meta property="og:site_name" content="Home Espresso India" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Roboto+Serif:wght@400;600;700&family=Roboto+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href={`${base}/styles.css`} />
    <link rel="icon" href={`data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop offset='0' stop-color='%236F4F38'/%3E%3Cstop offset='1' stop-color='%23735946'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='32' height='32' rx='8' fill='url(%23g)'/%3E%3Cpath d='M9 21q-1.2 0-2-.8-.8-.8-.8-2.2v-7q0-1.4.8-2.2.8-.8 2-.8h7v3h-7v7h7v3Zm10 0v-3h3v-7h-3V8h6v13Z' fill='%23fff'/%3E%3C/svg%3E`} />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a class="site-brand" href={`${base}/`}>Home Espresso India</a>
      </nav>
    </header>
    <main>
      <section class="home-hero">
        <h1>Home Espresso India</h1>
        <p class="lede">
          Practical buyer guides and reviews for home espresso in India.
          220V, hard water, monsoon humidity, INR pricing. Pillar 1 in
          progress: Choosing Your First Home Espresso Machine.
        </p>
      </section>
      <section class="home-articles">
        <h2>Latest</h2>
        {articles.map((a) => (
          <article class="home-card">
            <h2><a href={a.href}>{a.title}</a></h2>
            <p>{a.description}</p>
            <p class="meta">
              <span class="pillar-chip">Sub-pillar {a.pillar}</span>
              <span>{a.publishDate}</span>
            </p>
          </article>
        ))}
      </section>
      <footer class="affiliate-footer">
        <p>
          Affiliate disclosure: Pages on this site contain Amazon India
          affiliate links. We earn a small commission on qualifying
          purchases at no extra cost to you.
        </p>
      </footer>
    </main>
  </body>
</html>
